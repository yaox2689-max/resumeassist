# API Keys
DASHSCOPE_API_KEY=
DEEPSEEK_API_KEY=
MIMO_API_KEY=
OPENAI_API_KEY=

# Tracer (noop | langfuse)
TRACER=noop
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
# LANGFUSE_HOST=  # optional legacy alias for LANGFUSE_BASE_URL

# Storage
SQLITE_PATH=storage/db/app.db
JSONL_ROOT=storage/sessions

# Voice / Realtime
VOICE_DEFAULT_SESSION_MINUTES=15
VOICE_INACTIVITY_TIMEOUT_SECONDS=300

# Resume
RESUME_ROOT=storage/resumes
